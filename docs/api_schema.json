  "websocket": {
    "url": "ws://192.168.4.253/ws",
    "protocol": "JSON text frames",
    "direction": "bidirectional — device pushes evt:status at ~1Hz; client sends req:* commands",
    "event_type_field": "tp",
    "push_events": {
      "evt:status": {
        "description": "Machine telemetry, pushed at approximately 1Hz",
        "fields": {
          "tp": "string — 'evt:status'",
          "ct": "float — current boiler temperature (°C)",
          "tt": "float — target temperature (°C)",
          "pr": "float — current pressure (bar)",
          "pt": "float — target pressure (bar)",
          "fl": "float — current flow rate (ml/s)",
          "m": "int — machine mode (0=Standby, 1=Brew, 2=Steam, 3=Water, 4=Grind)",
          "p": "string — selected profile display name",
          "puid": "string — selected profile ID (short key e.g. '3zT2ydcV9G')",
          "cp": "bool — pressure capability available",
          "cd": "bool — dimming capability available",
          "tw": "float — target weight (g, 0 if not set)",
          "bta": "bool — volumetric (brew-by-weight) available",
          "bt": "int — brew target value",
          "btd": "int — brew target duration (ms)",
          "led": "bool — LED control available",
          "gtd": "int — grind target duration (ms)",
          "gtv": "int — grind target volume (ml)",
          "gt": "int — grind target type (0=time, 1=volume)",
          "gact": "int — grind active",
          "bw": "float — current weight from BLE scale (g)",
          "cw": "float — current weight",
          "bc": "bool — BLE scale connected",
          "process": "object|null — present when shot is active, fields: a=active(bool), e=ended(bool)"
        },
        "sample": {
