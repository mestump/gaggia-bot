    "request_response_pattern": "Client sends req:* with rid field (UUID), device responds with res:* matching rid",
    "mode_values": {
      "0": "Standby — machine is idle",
      "1": "Brew — brewing espresso",
      "2": "Steam — steaming",
      "3": "Water — dispensing water",
      "4": "Grind — grinding"
    },
    "shot_detection_strategy": "Watch evt:status.m field. Shot starts when m transitions to 1 (Brew) with process.a=true. Shot ends when process.e=true or m transitions back to 0. After shot ends, new record appears in /api/history/index.bin."
  },

