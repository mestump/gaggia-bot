    "GET /api/history/index.bin": {
      "content_type": "application/octet-stream",
      "notes": "Binary SIDX format. Contains index of all shot records. NOT gzip-compressed. See sidx_format below.",
      "sidx_format": {
        "magic": "SIDX (0x58444953 LE = 0x53494458)",
        "header_size_bytes": 32,
        "header_fields": {
          "0:4": "magic u32 = 0x58444953",
          "4:6": "version u16 (observed: 1)",
          "6:8": "record_size u16 (observed: 128)",
          "8:12": "num_records u32",
          "12:16": "next_id u32 (same as num_records when no deletions)",
          "16:32": "padding zeros"
        },
        "record_size_bytes": 128,
        "record_fields": {
          "0:4": "id u32 — shot sequential ID, used in filename",
          "4:8": "timestamp u32 — unix epoch seconds",
          "8:12": "data_size u32 — size of .slog file in bytes",
          "12:16": "flags u32 — bit 0=completed, bit 1=deleted, bit 2=hasNotes",
          "16:32": "profile_id char[16] — null-padded ASCII short ID (e.g. '3zT2ydcV9G')",
          "32:48": "unknown/padding",
          "48:80": "profile_name char[32] — null-padded ASCII display name (e.g. 'Lucy Adaptive')",
          "80:128": "padding"
        },
        "volume_scale": 10,
        "volume_field_in_flags_u16_at_byte_12_13": "volume_raw / 10 = ml"
      },
      "sample_parsed_records": [
        {"id": 0, "timestamp": 1771369229, "timestamp_human": "2026-02-17 18:00:29", "data_size": 44945, "profile_id": "adapt", "profile_name": "Adaptive v2"},
        {"id": 51, "timestamp": 1772914899, "timestamp_human": "2026-03-07 15:21:39", "data_size": 48092, "profile_id": "3zT2ydcV9G", "profile_name": "Lucy Adaptive"}
      ],
      "total_shots_observed": 52
    },
    "GET /api/history/{id:06d}.slog": {
      "content_type": "application/octet-stream",
      "notes": "Shot telemetry file. Binary SHOT format. id is zero-padded to 6 digits (e.g. '000051'). NOT gzip-compressed. See slog_format below.",
      "url_pattern": "/api/history/{id}.slog where id = str(shot_id).zfill(6)",
      "slog_format": {
        "magic": "SHOT (0x544f4853)",
        "versions_seen": [5],
        "header_size": {
          "v1-v4": 128,
          "v5+": 512
        },
        "header_fields_v5": {
          "0:4": "magic u32",
          "4": "version u8 (observed: 5)",
          "5": "fields_byte_count u8 — bytes per sample (observed: 26 = 13 fields * 2 bytes)",
          "6:8": "header_size u16 (512 for v5)",
          "8:10": "sample_interval_ms u16 (observed: 250ms)",
          "12:16": "fields_mask u32 — bitmask of active fields",
          "16:20": "samples_expected u32 — number of samples (0 = ongoing/incomplete)",
          "20:24": "final_volume_raw u32",
          "24:28": "timestamp u32 — unix epoch seconds",
          "28:60": "profile_id char[32] — null-padded ASCII",
          "60:108": "profile_name char[48] — null-padded ASCII",
          "108:110": "volume_raw u16 — final_volume / 10 = ml",
          "110:458": "phase_transitions — up to 12 phases, 29 bytes each",
          "458": "num_phases u8",
          "512+": "sample data"
        },
        "phase_transition_struct_29_bytes": {
          "0:2": "sample_index u16",
          "2": "phase_number u8",
          "4:29": "phase_name char[25] — null-padded ASCII"
        },
        "fields_bitmask": {
          "bit_0": {"name": "t", "type": "uint16", "unit": "ms", "transform": "raw * sample_interval_ms"},
          "bit_1": {"name": "tt", "type": "uint16", "scale": 10, "unit": "°C", "description": "target temperature"},
          "bit_2": {"name": "ct", "type": "uint16", "scale": 10, "unit": "°C", "description": "current temperature"},
          "bit_3": {"name": "tp", "type": "uint16", "scale": 10, "unit": "bar", "description": "target pressure"},
          "bit_4": {"name": "cp", "type": "uint16", "scale": 10, "unit": "bar", "description": "current pressure"},
          "bit_5": {"name": "fl", "type": "int16", "scale": 100, "unit": "ml/s", "description": "actual flow rate"},
          "bit_6": {"name": "tf", "type": "int16", "scale": 100, "unit": "ml/s", "description": "target flow"},
          "bit_7": {"name": "pf", "type": "int16", "scale": 100, "unit": "ml/s", "description": "predicted flow"},
          "bit_8": {"name": "vf", "type": "int16", "scale": 100, "unit": "ml/s", "description": "volumetric flow"},
          "bit_9": {"name": "v", "type": "uint16", "scale": 10, "unit": "ml", "description": "volume (scale-based)"},
          "bit_10": {"name": "ev", "type": "uint16", "scale": 10, "unit": "ml", "description": "estimated volume"},
          "bit_11": {"name": "pr", "type": "uint16", "scale": 100, "description": "pump ratio"},
          "bit_12": {"name": "systemInfo", "type": "uint16", "scale": null, "description": "bitmask: bit0=shotStartedVolumetric, bit1=currentlyVolumetric, bit2=bluetoothScaleConnected, bit3=volumetricAvailable, bit4=extendedRecording"}
        },
        "fields_mask_v5_example": "0x00001fff (all 13 fields active)",
        "sample_interval_ms_observed": 250,
        "phases_observed": ["Prefill", "Fill", "Compressing", "Dripping", "Pressurize", "Extraction"],
